// Test Airy functions

import specialfn

var values = (
    ( airyAi(0.0), 0.3550280538878172 ),
    ( airyAiPrime(0.0), -0.2588194037928068 ),
    ( airyBi(0.0), 0.6149266274460007 ),
    ( airyBiPrime(0.0), 0.4482883573538264 ),
    ( airyAi(1.0), 0.13529241631288141 ),
    ( airyBi(1.0), 1.2074235949528713 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
