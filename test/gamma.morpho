// Test gamma function

import specialfn 

var values = (
    ( 1, 1.0 ),
    ( 2.8868387551553275402, 1.8063179094058527158 ),
    ( 24.579618872917871846, 1.62288935029700004e23 ),
    ( 39.992946752410208178, 1.98757750985747652e46 ),
    ( 62.388080839356408868, 2.51342158548240471e84 ),
    ( 66.482001193653029872, 6.2019901823060085e91 ),
    ( 96.776176038456280558, 3.5669602251185284e149 ),
    ( 101.60689455644462826, 1.53427299902706647e159 ),
    ( 130.97662350994982947, 5.770832813570162e219 ),
    ( 139.069125088152987, 9.7275307576092198e236 ),
    ( 166.39472359780840973, 4.076889902484436e296 ),
    ( 171.6, 1.5858969096673028652e308 )
)

var tol = 1e-13 // Can we do better than this? 

for (v in values) {
    var x = v[0]
    var g = gamma(x)
    var gp = v[1]
    if (abs(1-gp/g) > tol) print "Fail: ${x}, ${g}, ${abs(1-gp/g)}"
}
