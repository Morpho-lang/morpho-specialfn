// Test integer-order Bessel functions

import specialfn

var values = (
    ( besselJ(2, 1), 0.11490348493190049 ),
    ( besselY(2, 1), -1.6506826068162543 ),
    ( besselJ(3, 1), 0.019563353982668407 ),
    ( besselY(3, 1), -5.821517605964729 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
