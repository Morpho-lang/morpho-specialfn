// Test hypergeometric functions

import specialfn

var values = (
    ( confluentHypergeometric(1.0, 1.0, 1.0), 2.718281828459045 ),
    ( confluentHypergeometric(2.0, 2.0, 0.5), 1.6487212707001282 ),
    ( hypergeometric2F1(1.0, 1.0, 2.0, 0.5), 1.3862943611198906 ),
    ( hypergeometric2F1(1.0, 2.0, 2.0, 0.5), 2.0 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
