// Test classical integral functions

import specialfn

var values = (
    ( expIntegralEi(1.0), 1.8951178163559368 ),
    ( expIntegralE(1, 1.0), 0.21938393439552029 ),
    ( expIntegralE(2, 1.0), 0.14849550677592205 ),
    ( dawson(1.0), 0.5380795069127684 ),
    ( fresnelS(1.0), 0.43825914739035476 ),
    ( fresnelC(1.0), 0.779893400376823 ),
    ( sineIntegral(1.0), 0.946083070367183 ),
    ( cosineIntegral(1.0), 0.33740392290096816 ),
    ( sinhIntegral(1.0), 1.0572508753757286 ),
    ( coshIntegral(1.0), 0.8378669409802082 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
