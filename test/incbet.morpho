// Test incomplete beta functions

import specialfn

var values = (
    ( incbet(1, 1, 0.25), 0.25 ),
    ( incbet(2, 1, 0.5), 0.25 ),
    ( incbi(1, 1, 0.25), 0.25 ),
    ( incbi(2, 1, 0.25), 0.5 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
