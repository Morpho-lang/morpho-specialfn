// Test erf. functions

import specialfn

var values = (
    ( erf(0), 0.0 ),
    ( erf(0.5), 0.52049987781304653768 ),
    ( erf(1), 0.84270079294971486934 ),
    ( erfc(0), 1.0 ),
    ( erfc(0.5), 0.47950012218695346232 ),
    ( erfc(1), 0.15729920705028513066 )
)

var tol = 1e-13

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(1-xp/x) > tol && abs(xp-x) > tol) print "Fail: ${x}, ${xp}"
}
