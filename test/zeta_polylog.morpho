// Test zeta, dilog, polylog, and Struve functions

import specialfn

var values = (
    ( riemannZeta(2.0), 1.6449340668482264 ),
    ( riemannZetaMinusOne(2.0), 0.6449340668482264 ),
    ( hurwitzZeta(2.0, 2.0), 0.6449340668482264 ),
    ( dilog(0.0), 0.0 ),
    ( dilog(0.25), 0.26765263908273268 ),
    ( dilog(0.5), 0.58224052646501345 ),
    ( dilog(1.0), 1.6449340668482264 ),
    ( polylog(2, 1.0), 1.6449340668482264 ),
    ( polylog(2, 0.5), 0.58224052646501345 ),
    ( polylog(1, 0.5), 0.6931471805599453 ),
    ( struveH(0.0, 1.0), 0.5686566270482881 ),
    ( struveH(1.0, 1.0), 0.19845733620194442 )
)

var tol = 1e-12

for (v in values) {
    var x = v[0]
    var xp = v[1]
    if (abs(xp) > tol) {
        if (abs(1-x/xp) > tol) print "Fail: ${x}, ${xp}"
    } else {
        if (abs(x-xp) > tol) print "Fail: ${x}, ${xp}"
    }
}
